# Encryption key for OAuth2 token storage (32 bytes, base64 encoded)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# WhatsApp number(s) allowed to talk to the assistant, as JIDs
# (e.g. 6281234567890@s.whatsapp.net). Comma-separate several — the assistant
# runs on the account you pair (Integrations → WhatsApp QR) and answers these
# numbers; the FIRST one also receives reminders and the daily recap.
# Example (personal + work): 628...971@s.whatsapp.net,628...972@s.whatsapp.net
OWNER_JID=

# --- Database (required) ---
# The app runs on PostgreSQL (main data) + MongoDB (logs). Set the passwords for
# the bundled postgres/mongo services; docker-compose builds the POSTGRES_DSN /
# MONGO_URI the assistant uses from these.
POSTGRES_PASSWORD=
MONGO_PASSWORD=
# Or set the full connection strings directly (overrides the compose defaults):
# POSTGRES_DSN=postgres://assistant:pass@postgres:5432/assistant?sslmode=disable
# MONGO_URI=mongodb://root:pass@mongo:27017/?authSource=admin
# MONGO_DB=assistant_logs

# Names this deployment ("local" / "production"). Shown in the Logs run-detail
# copy so a pasted trace makes clear which database holds its data. Defaults to
# "local"; set to "production" on the deployed instance.
APP_ENV=

# Override log level (optional: debug, info, warn, error)
LOG_LEVEL=

# Web interface password (required when web is enabled)
WEB_PASSWORD=

# NOTE: The LLM provider, API key, model, and base URL are configured at runtime
# from the Settings page (stored encrypted in the database) — not via env vars.

# --- Email / SMTP (optional) ---
# Transactional email transport, used only for the "forgot password" reset mail.
# Leave SMTP_HOST empty to keep the feature disabled: the forgot-password
# endpoint then responds "password reset by email is not available". Set these
# to enable it (works with any SMTP provider — Gmail app-passwords, SendGrid,
# Mailgun, …).
#   Port 465 uses implicit TLS; 587 (default for most providers) uses STARTTLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Sender address + display name shown on the reset email. SMTP_FROM_ADDRESS
# falls back to SMTP_USER when empty.
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Personal Assistant
